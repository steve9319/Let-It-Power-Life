# Postgres connection string (added automatically when you attach Neon in Vercel)
DATABASE_URL=

# Transactional email via SMTP (Brevo). Get these from Brevo -> SMTP & API -> SMTP.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=            # Brevo SMTP login (e.g. 8xxxxx@smtp-brevo.com)
SMTP_APP_PASSWORD=    # Brevo SMTP key
# Visible sender (a Brevo-verified sender address) and display name
EMAIL_FROM=           # e.g. the verified sender address
EMAIL_FROM_NAME=Let It Power Life
# Replies go here (Arisa's inbox)
EMAIL_REPLY_TO=arisatan9319@gmail.com

# Admin login for /admin
ADMIN_EMAIL=arisatan9319@gmail.com
ADMIN_PASSWORD=

# Any long random string, used to sign session cookies
SESSION_SECRET=

# Vercel Blob token for photo uploads (added automatically when you attach Blob storage)
BLOB_READ_WRITE_TOKEN=
